{
  "expo": {
    "name": "Mi Bancolombia",
    "slug": "mi-bancolombia",
    "version": "2.3.2",
    "orientation": "portrait",
    "icon": "./assets/images/pwa-icon.png",
    "scheme": "mi-bancolombia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/pwa-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bancolombia.miapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/pwa-icon.png",
        "backgroundColor": "#0D0D0F"
      },
      "package": "com.bancolombia.miapp"
    },
    "web": {
      "favicon": "./assets/images/pwa-icon.png",
      "bundler": "metro",
      "manifest": {
        "name": "Mi Bancolombia",
        "short_name": "Bancolombia",
        "description": "Tu banco en la palma de tu mano",
        "background_color": "#0D0D0F",
        "theme_color": "#FDDA24",
        "display": "standalone",
        "orientation": "portrait",
        "icons": [
          {
            "src": "./assets/images/pwa-icon.png",
            "sizes": "192x192",
            "type": "image/png"
          },
          {
            "src": "./assets/images/pwa-icon.png",
            "sizes": "512x512",
            "type": "image/png"
          }
        ]
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
