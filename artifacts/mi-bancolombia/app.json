{
  "expo": {
    "name": "Mi Bancolombia",
    "slug": "mi-bancolombia",
    "owner": "mibancolombia",
    "version": "2.3.2",
    "orientation": "portrait",
    "icon": "./assets/images/pwa-icon.png",
    "scheme": "mi-bancolombia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/pwa-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bancolombia.miapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/pwa-icon.png",
        "backgroundColor": "#FDDA24"
      },
      "package": "com.bancolombia.miapp",
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_PHONE_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/pwa-icon.png",
      "bundler": "metro",
      "manifest": {
        "name": "Mi Bancolombia",
        "short_name": "Bancolombia",
        "description": "Tu banco en la palma de tu mano",
        "lang": "es-CO",
        "start_url": "/",
        "scope": "/",
        "background_color": "#0D0D0F",
        "theme_color": "#FDDA24",
        "display": "standalone",
        "orientation": "portrait",
        "categories": ["finance"],
        "icons": [
          {
            "src": "./assets/images/pwa-icon.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
          },
          {
            "src": "./assets/images/pwa-icon.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any maskable"
          }
        ]
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://bancolombia--appbancolombiav.replit.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-contacts",
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir acceso a tus fotos y videos.",
          "savePhotosPermission": "Permitir guardar fotos y videos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/pwa-icon.png",
          "color": "#FDDA24",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      "./plugins/withSmsReader"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "1123da6a-aea4-411f-a792-ea76835c7f00"
      }
    }
  }
}
